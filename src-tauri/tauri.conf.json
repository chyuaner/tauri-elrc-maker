{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-elrc-maker",
  "version": "0.1.0",
  "identifier": "tw.yuaner.tauri-elrc-maker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000/?tauri=1",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LRC Maker Enhanced",
        "width": 1368,
        "height": 768,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
